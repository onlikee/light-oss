# =============================================================================
# 后端配置
# =============================================================================

# MySQL 容器初始化时创建的数据库名称。
MYSQL_DATABASE=light-oss
# MySQL 常规连接使用的用户名。
MYSQL_USER=root
# MYSQL_USER 对应的登录密码。
MYSQL_PASSWORD=123456
# MySQL root 账号的登录密码。
MYSQL_ROOT_PASSWORD=123456

# 后端运行环境，常见值为 development 或 production。
APP_ENV=development
# 后端 HTTP 服务监听地址和端口。
APP_ADDR=:18271
# 后端对外访问基地址，用于生成签名下载链接等场景。
APP_PUBLIC_BASE_URL=http://localhost:18271
# 后端对象文件在本机或容器中的存储根目录。Linux使用./light-oss-data/storage，Windows使用.\light-oss-data\storage。
APP_STORAGE_ROOT=.\light-oss-data\storage
# 单个上传请求允许的最大文件大小，单位为字节。
APP_MAX_UPLOAD_SIZE_BYTES=1073741824
# 处理 multipart/form-data 时允许驻留内存的最大大小，单位为字节。
APP_MAX_MULTIPART_MEMORY_BYTES=8388608

# 接口限流的每秒允许请求数。
APP_RATE_LIMIT_RPS=5
# 接口限流的突发请求容量。
APP_RATE_LIMIT_BURST=10

# 后端 Bearer Token 列表，多个值使用英文逗号分隔。
APP_BEARER_TOKENS=light-oss
# 用于生成和校验签名下载链接的密钥。
APP_SIGNING_SECRET=change-me-in-local-dev
# 默认签名下载链接有效期，单位为秒。
APP_DEFAULT_SIGNED_URL_TTL_SECONDS=300
# 签名下载链接允许设置的最大有效期，单位为秒。
APP_MAX_SIGNED_URL_TTL_SECONDS=86400

# HTTP 请求头读取超时时间，单位为秒。
APP_READ_HEADER_TIMEOUT_SECONDS=10
# 服务优雅关闭等待超时时间，单位为秒。
APP_SHUTDOWN_TIMEOUT_SECONDS=10

# 后端连接 MySQL 使用的 DSN 字符串。
DB_DSN=root:123456@tcp(localhost:3306)/light-oss?charset=utf8mb4&parseTime=True&loc=UTC&multiStatements=true
# 数据库连接池允许打开的最大连接数。
DB_MAX_OPEN_CONNS=10
# 数据库连接池允许保留的最大空闲连接数。
DB_MAX_IDLE_CONNS=5
# 单个数据库连接的最长复用时间，单位为分钟。
DB_CONN_MAX_LIFETIME_MINUTES=30

# =============================================================================
# 前端配置
# =============================================================================

# 前端首次加载时默认使用的 API 基地址。
VITE_DEFAULT_API_BASE_URL=http://localhost:18271
# 前端首次加载时默认填充的 Bearer Token。
VITE_DEFAULT_BEARER_TOKEN=light-oss
